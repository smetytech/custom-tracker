{
	"name": "@smety/tracker",
	"version": "1.3.0",
	"description": "Lightweight analytics tracker with consent support, auto-click tracking, SPA navigation, and Expo/React Native support",
	"main": "dist/tracker.es.js",
	"module": "dist/tracker.es.js",
	"types": "dist/index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"import": "./dist/tracker.es.js",
			"require": "./dist/tracker.umd.js",
			"types": "./dist/index.d.ts"
		},
		"./expo": {
			"import": "./dist/expo.es.js",
			"require": "./dist/expo.umd.js",
			"types": "./dist/expo.d.ts"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "vite build --config vite.config.ts && vite build --config vite.config.expo.ts && tsc -p tsconfig.web.json --emitDeclarationOnly --declaration --outDir dist && tsc -p tsconfig.expo.json --emitDeclarationOnly --declaration --outDir dist",
		"build:web": "vite build --config vite.config.ts",
		"build:expo": "vite build --config vite.config.expo.ts",
		"build:all": "npm run build:web && npm run build:expo && tsc -p tsconfig.web.json --emitDeclarationOnly --declaration --outDir dist && tsc -p tsconfig.expo.json --emitDeclarationOnly --declaration --outDir dist",
		"dev": "vite build --watch",
		"typecheck": "tsc -p tsconfig.web.json --noEmit && tsc -p tsconfig.expo.json --noEmit",
		"typecheck:web": "tsc -p tsconfig.web.json --noEmit",
		"typecheck:expo": "tsc -p tsconfig.expo.json --noEmit"
	},
	"keywords": [
		"analytics",
		"tracker",
		"privacy",
		"consent",
		"spa",
		"expo",
		"react-native",
		"mobile"
	],
	"author": "smetytech",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^25.6.0",
		"@types/react": "^18.2.0",
		"typescript": "^5.3.0",
		"vite": "^5.0.0"
	},
	"peerDependencies": {
		"@react-native-async-storage/async-storage": ">=1.19.0",
		"@react-navigation/native": ">=6.0.0",
		"expo-application": ">=5.0.0",
		"expo-device": ">=5.0.0",
		"expo-localization": ">=14.0.0",
		"expo-location": ">=16.0.0",
		"react": ">=18.0.0",
		"react-native": ">=0.70.0"
	},
	"peerDependenciesMeta": {
		"react": {
			"optional": true
		},
		"react-native": {
			"optional": true
		},
		"@react-navigation/native": {
			"optional": true
		},
		"@react-native-async-storage/async-storage": {
			"optional": true
		},
		"expo-device": {
			"optional": true
		},
		"expo-localization": {
			"optional": true
		},
		"expo-location": {
			"optional": true
		},
		"expo-application": {
			"optional": true
		}
	}
}
