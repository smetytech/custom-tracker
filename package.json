{
	"name": "@smety/tracker",
	"version": "1.0.0",
	"description": "Lightweight analytics tracker with consent support, auto-click tracking, and SPA navigation",
	"main": "dist/tracker.umd.js",
	"module": "dist/tracker.es.js",
	"types": "dist/index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"import": "./dist/tracker.es.js",
			"require": "./dist/tracker.umd.js",
			"types": "./dist/index.d.ts"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "vite build && tsc --emitDeclarationOnly --declaration --outDir dist",
		"dev": "vite build --watch",
		"typecheck": "tsc --noEmit"
	},
	"keywords": [
		"analytics",
		"tracker",
		"privacy",
		"consent",
		"spa"
	],
	"author": "smetytech",
	"license": "MIT",
	"devDependencies": {
		"typescript": "^5.3.0",
		"vite": "^5.0.0"
	}
}
